<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_dark">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginHorizontal="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⊞  Switch Build  ▾"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:background="@drawable/bg_switch_build_pill"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- Badge count -->
        <TextView
            android:id="@+id/tvBadgeCount"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="0"
            android:textColor="@color/bg_dark"
            android:textSize="11sp"
            android:gravity="center"
            android:fontFamily="sans-serif-black"
            android:background="@drawable/bg_accent_circle"
            android:layout_marginEnd="10dp" />

        <ImageButton
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_share"
            android:contentDescription="Export build" />

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Build title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="My Scratch Build"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:paddingTop="20dp"
                android:paddingHorizontal="16dp" />

            <TextView
                android:id="@+id/tvLastUpdated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last updated just now"
                android:textColor="@color/text_muted2"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="12dp" />

            <!-- Stats 2x2 grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                android:useDefaultMargins="false">

                <!-- Price -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="14dp"
                    android:layout_margin="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="€"
                        android:textColor="@color/text_muted"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvTotalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="€0.00"
                        android:textColor="@color/green_price"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black"
                        android:paddingTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total cost"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:paddingTop="2dp" />

                </LinearLayout>

                <!-- Compatibility -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="14dp"
                    android:layout_margin="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Compatible"
                        android:textColor="@color/green_price"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_compat_badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Compatibility"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:paddingTop="8dp" />

                </LinearLayout>

                <!-- Wattage -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="14dp"
                    android:layout_margin="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tvWattage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0W"
                        android:textColor="@color/amber"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black"
                        android:paddingTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Est. power draw"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:paddingTop="2dp" />

                </LinearLayout>

                <!-- 3DMark -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="14dp"
                    android:layout_margin="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3DMARK"
                        android:textColor="@color/accent"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tv3DMarkScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N/A"
                        android:textColor="@color/amber"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black"
                        android:paddingTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Perf. score"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:paddingTop="2dp" />

                </LinearLayout>

            </GridLayout>

            <!-- Section label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COMPONENTS"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="6dp" />

            <!-- Dynamic part rows injected here -->
            <LinearLayout
                android:id="@+id/llPartsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp" />

            <!-- Finalize button -->
            <TextView
                android:id="@+id/tvFinalizeLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="Generate Parts Summary" />

            <Button
                android:id="@+id/btnFinalizeBuild"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:text="Generate Parts Summary"
                android:textColor="@color/bg_dark"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                android:background="@drawable/bg_button_accent"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_dark">

        <LinearLayout
            android:id="@+id/navBuild"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔧" android:textSize="20sp" android:gravity="center" android:layout_gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Build" android:textColor="@color/accent" android:textSize="10sp"
                android:gravity="center" android:layout_gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCompare"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🖥" android:textSize="20sp" android:gravity="center" android:layout_gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Compare" android:textColor="@color/text_muted" android:textSize="10sp"
                android:gravity="center" android:layout_gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCommunity"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥" android:textSize="20sp" android:gravity="center" android:layout_gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Community" android:textColor="@color/text_muted" android:textSize="10sp"
                android:gravity="center" android:layout_gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙" android:textSize="20sp" android:gravity="center" android:layout_gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" android:textColor="@color/text_muted" android:textSize="10sp"
                android:gravity="center" android:layout_gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="20sp" android:gravity="center" android:layout_gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textColor="@color/text_muted" android:textSize="10sp"
                android:gravity="center" android:layout_gravity="center"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>