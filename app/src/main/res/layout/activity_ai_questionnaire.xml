<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <!-- ── Top bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back arrow -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:tint="#CBD5E1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvStepLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question 1 of 10"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Build Your Profile"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Step counter badge -->
        <TextView
            android:id="@+id/tvStepBadge"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="1"
            android:textColor="#0F172A"
            android:textSize="16sp"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:background="@drawable/bg_accent_circle" />
    </LinearLayout>

    <!-- ── Progress bar ── -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:layout_marginHorizontal="20dp"
        android:max="10"
        android:progress="1"
        android:progressDrawable="@drawable/progress_bar_accent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── ViewPager2 (swipeable question cards) ── -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerQuestions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:overScrollMode="never" />

    <!-- ── Bottom navigation bar ── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Previous button (hidden on Q1) -->
        <Button
            android:id="@+id/btnPrevious"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="← Back"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_button_ghost"
            android:paddingHorizontal="20dp"
            android:visibility="invisible" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Next / Generate button -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Next →"
            android:textColor="#0F172A"
            android:textSize="15sp"
            android:fontFamily="sans-serif-bold"
            android:background="@drawable/bg_button_accent"
            android:paddingHorizontal="28dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
