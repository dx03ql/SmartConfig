<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How do you want to build?"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your preferred approach"
            android:textColor="#CBD5E1"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp"/>

        <!-- OPTION 1: AI GENERATED -->
        <LinearLayout
            android:id="@+id/cardModeAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="#6EE2F5"
                    android:background="#0F172A"
                    android:padding="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Generated Build"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recommended"
                        android:textColor="#6EE2F5"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioAI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#6EE2F5"
                    android:checked="true"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Let AI design your perfect build from scratch based on your usage and budget. Best for beginners or anyone who wants a hassle-free experience."
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="3dp"/>

            <!-- TAGS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Beginner-friendly"
                    android:textColor="#6EE2F5"
                    android:textSize="11sp"
                    android:background="#0F172A"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Optimized"
                    android:textColor="#6EE2F5"
                    android:textSize="11sp"
                    android:background="#0F172A"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- OPTION 2: MODIFY A READY BUILD -->
        <LinearLayout
            android:id="@+id/cardModeModify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:tint="#6EE2F5"
                    android:background="#0F172A"
                    android:padding="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start from a Template"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Modify a ready-made build"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioModify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#6EE2F5"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pick a pre-configured build that matches your profile, then swap out any parts you don't like. Great if you have a few preferences but want a solid starting point."
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="3dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intermediate"
                    android:textColor="#6EE2F5"
                    android:textSize="11sp"
                    android:background="#0F172A"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flexible"
                    android:textColor="#6EE2F5"
                    android:textSize="11sp"
                    android:background="#0F172A"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- OPTION 3: BUILD FROM SCRATCH -->
        <LinearLayout
            android:id="@+id/cardModeScratch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_menu_add"
                    android:tint="#6EE2F5"
                    android:background="#0F172A"
                    android:padding="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Build from Scratch"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full manual control"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioScratch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#6EE2F5"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose every component manually from our full catalog. AI will still flag any compatibility issues in real time. For enthusiasts who know exactly what they want."
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="3dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Advanced"
                    android:textColor="#6EE2F5"
                    android:textSize="11sp"
                    android:background="#0F172A"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full control"
                    android:textColor="#6EE2F5"
                    android:textSize="11sp"
                    android:background="#0F172A"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- CONFIRM BUTTON -->
        <Button
            android:id="@+id/btnBuildModeNext"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Continue"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#0F172A"
            android:backgroundTint="#6EE2F5"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>

</ScrollView>