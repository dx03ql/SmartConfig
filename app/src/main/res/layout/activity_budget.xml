<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Your Budget"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We'll find the best components within your range"
            android:textColor="#CBD5E1"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <!-- BUDGET DISPLAY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected Budget"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/tvBudgetDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$500"
                android:textColor="#6EE2F5"
                android:textSize="48sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>

            <SeekBar
                android:id="@+id/seekBarBudget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:max="9"
                android:progress="2"
                android:progressTint="#6EE2F5"
                android:thumbTint="#6EE2F5"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="$200"
                    android:textColor="#64748B"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="$5000+"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:gravity="end"/>

            </LinearLayout>

        </LinearLayout>

        <!-- BUDGET TIER CARDS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quick Select"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp"/>

        <!-- ENTRY -->
        <LinearLayout
            android:id="@+id/cardBudgetEntry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E293B"
            android:padding="18dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entry Level"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Office, web browsing, light tasks"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$200–$500"
                android:textColor="#6EE2F5"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- MID RANGE -->
        <LinearLayout
            android:id="@+id/cardBudgetMid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E293B"
            android:padding="18dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mid Range"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1080p gaming, content creation"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$500–$1000"
                android:textColor="#6EE2F5"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- HIGH END -->
        <LinearLayout
            android:id="@+id/cardBudgetHigh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E293B"
            android:padding="18dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High End"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1440p/4K gaming, workstation"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$1000–$2000"
                android:textColor="#6EE2F5"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ENTHUSIAST -->
        <LinearLayout
            android:id="@+id/cardBudgetEnthusiast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E293B"
            android:padding="18dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enthusiast"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No compromises, max performance"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$2000+"
                android:textColor="#6EE2F5"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- NEXT BUTTON -->
        <Button
            android:id="@+id/btnBudgetNext"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Continue"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#0F172A"
            android:backgroundTint="#6EE2F5"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>

</ScrollView>