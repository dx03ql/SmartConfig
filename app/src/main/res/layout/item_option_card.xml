<?xml version="1.0" encoding="utf-8"?>
<!--
    item_option_card.xml
    Represents one selectable answer option within a question page.
    Selected state: accent border (#6EE2F5) + tinted background.
    Unselected state: muted border (#1E293B).
    State is toggled programmatically in QuestionPagerAdapter.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardOption"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#2D3F55"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Option emoji -->
        <TextView
            android:id="@+id/tvOptionEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔵"
            android:textSize="22sp" />

        <!-- Option label -->
        <TextView
            android:id="@+id/tvOptionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="Option label"
            android:textColor="#CBD5E1"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingMultiplier="1.3" />

        <!-- Selection indicator (radio dot) -->
        <View
            android:id="@+id/viewSelectionDot"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_radio_unselected"
            android:layout_marginStart="12dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
