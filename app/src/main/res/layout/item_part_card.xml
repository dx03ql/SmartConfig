<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_rounded"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- Thumbnail box -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginEnd="14dp">

        <!-- Dark background circle -->
        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_dark_rounded" />

        <!-- Category emoji placeholder -->
        <TextView
            android:id="@+id/tvPartIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="🔲"
            android:textSize="26sp"
            android:gravity="center" />

        <!-- 3D badge bottom-left -->
        <TextView
            android:id="@+id/tv3DBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="4dp"
            android:text="⟳ 3D"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:fontFamily="sans-serif-black"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_3d_badge"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Part info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Sponsored badge -->
        <TextView
            android:id="@+id/tvSponsored"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sponsored"
            android:textColor="@color/amber"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:paddingHorizontal="7dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_sponsored_badge"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <!-- Part name -->
        <TextView
            android:id="@+id/tvPartName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Part Name"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingMultiplier="1.2" />

        <!-- Price -->
        <TextView
            android:id="@+id/tvPartPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="€0.00"
            android:textColor="@color/green_price"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            android:paddingTop="4dp" />

        <!-- Spec line -->
        <TextView
            android:id="@+id/tvPartSpec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spec"
            android:textColor="@color/text_muted2"
            android:textSize="12sp"
            android:paddingTop="2dp" />

        <!-- Add to build button -->
        <TextView
            android:id="@+id/tvAddBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:text="+  Add to Build"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_add_button_outline" />

    </LinearLayout>

</LinearLayout>
