<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SmartConfigPC" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryVariant">@color/brand_dark</item>
        <item name="colorOnPrimary">@color/brand_dark</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/brand_dark</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Wizard Step Badge -->
    <style name="Widget.SmartConfig.StepBadge">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:background">@drawable/bg_step_badge</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.SmartConfig.Card">
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/border_tertiary</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="cardBackgroundColor">@color/bg_primary</item>
    </style>

    <!-- Option button -->
    <style name="Widget.SmartConfig.OptionButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">@drawable/bg_option_btn</item>
        <item name="android:gravity">start</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Nav button -->
    <style name="Widget.SmartConfig.NavNext">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:background">@drawable/bg_btn_next</item>
        <item name="android:textColor">@color/brand_dark</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.SmartConfig.NavBack">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Section label -->
    <style name="Widget.SmartConfig.SectionLabel">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
    <!-- The missing style the error complained about -->
    <style name="Widget.SmartConfig" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>